# ---------------------------------------------------------------------------
# R Session Artefacts
# ---------------------------------------------------------------------------
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj
 
 
# ---------------------------------------------------------------------------
# Credentials & Secrets
# ---------------------------------------------------------------------------
.Renviron
.netrc
.env
.env.*
!.env.example          # keep the example template tracked
 
 
# ---------------------------------------------------------------------------
# Data
# ---------------------------------------------------------------------------
# All data directories are excluded. Raw inputs are archived on Zenodo
data/
 
 
# ---------------------------------------------------------------------------
# Validation outputs (scripts stay tracked; rendered artefacts do not)
# ---------------------------------------------------------------------------
# Rendered HTML reports produced by Quarto
results/validation_old_version/**/*.html
 
# Quarto intermediate files generated during rendering
results/validation_old_version/**/*.knit.md
results/validation_old_version/**/*_files/
scripts/validation_old_version/**/*_files/
scripts/validation_old_version/**/*.knit.md
 
# Comparison artefacts (Parquet files written by compare_ground_stations etc.)
results/validation_old_version/**/ground_station_comparison/
results/validation_old_version/**/*.parquet
results/validation_old_version/**/*.csv
results/validation_old_version/**/*.rds
 
# PDF maps that are outputs of validation scripts (not paper figures)
results/validation_old_version/**/*.pdf
 
 
# ---------------------------------------------------------------------------
# Results — untracked interactive map build artefacts
# ---------------------------------------------------------------------------
results/figures/maps_interactive/*_files/
 
 
# ---------------------------------------------------------------------------
# OS Files
# ---------------------------------------------------------------------------
.DS_Store
**/.DS_Store
Thumbs.db
 
 
# ---------------------------------------------------------------------------
# Legacy & Test Artefacts
# ---------------------------------------------------------------------------
tests/_cache/
tests/_out/
