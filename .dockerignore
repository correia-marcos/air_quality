# ---------------------------------------------------------------------------
# Git Metadata
# ---------------------------------------------------------------------------
.git
.gitignore
 
 
# ---------------------------------------------------------------------------
# OS Files
# ---------------------------------------------------------------------------
.DS_Store
**/.DS_Store
Thumbs.db
 
 
# ---------------------------------------------------------------------------
# R Session Artefacts
# ---------------------------------------------------------------------------
.Rproj.user
.Rhistory
.RData
.Ruserdata
*.Rproj
 
 
# ---------------------------------------------------------------------------
# renv Package Cache (restored at build time; do not copy from host)
# ---------------------------------------------------------------------------
renv/library
 
 
# ---------------------------------------------------------------------------
# Data
# ---------------------------------------------------------------------------
# Raw and downloaded data is never baked into the image.
# It is mounted at runtime via docker-compose volumes or copied separately.
data/raw/
data/downloads/
data/_legacy/
data/interim/
data/processed/
 
 
# ---------------------------------------------------------------------------
# Validation Infrastructure (internal audit — not part of the paper pipeline)
# ---------------------------------------------------------------------------
# Comparison scripts against the coauthor's legacy code
scripts/validation_old_version/
 
# Validation utility functions (sourced only by validation scripts)
src/general_utilities/config_utils_validation_old_version.R
 
# All validation outputs and reports
results/validation_old_version/
 
 
# ---------------------------------------------------------------------------
# Results (reproducible from code; not needed to build the image)
# ---------------------------------------------------------------------------
results/figures/
results/tables/
 
 
# ---------------------------------------------------------------------------
# Credentials & Secrets
# ---------------------------------------------------------------------------
.Renviron
.netrc
.env
.env.*
!.env.example
 
 
# ---------------------------------------------------------------------------
# Quarto / Pandoc Intermediate Files
# ---------------------------------------------------------------------------
**/*_files/
**/*.knit.md
 
 
# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
doc/
fonts/
README.md
LICENSE.md